<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="match_parent">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/fragmentLibraryRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
                android:id="@+id/library_scroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fillViewport="true">

            <LinearLayout
                    android:id="@+id/library_sections"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="24dp">

                <!-- Pull List -->
                <LinearLayout
                        android:id="@+id/library_section_pull"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="PULL">

                    <LinearLayout
                            android:id="@+id/library_pull_header_row"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone"
                            android:background="?attr/selectableItemBackground">

                        <TextView
                                android:id="@+id/library_pull_header"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/menu_pull_list"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                        <ImageButton
                                android:id="@+id/library_pull_settings"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/library_pull_settings_cd"
                                android:src="@drawable/ic_settings_24"
                                android:scaleType="centerInside"
                                android:padding="6dp"/>

                        <ImageView
                                android:id="@+id/library_pull_chevron"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_expand_less_24"
                                android:contentDescription="@string/library_pull_toggle"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/library_pull_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            android:clipToPadding="false"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:visibility="gone"/>

                    <TextView
                            android:id="@+id/library_pull_empty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="8dp"
                            android:text="@string/library_pull_empty_short"
                            android:textSize="13sp"
                            android:visibility="gone"/>
                </LinearLayout>

                <!-- Local files (user-imported) -->
                <LinearLayout
                        android:id="@+id/library_section_local"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="LOCAL">

                    <LinearLayout
                            android:id="@+id/library_local_header_row"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:background="?attr/selectableItemBackground">

                        <TextView
                                android:id="@+id/library_local_header"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/library_local_header"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                        <ImageButton
                                android:id="@+id/library_local_add"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_input_add"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="@string/library_local_add"/>

                        <ImageView
                                android:id="@+id/library_local_chevron"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_expand_less_24"
                                android:contentDescription="@string/library_local_toggle"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/library_local_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            android:clipToPadding="false"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:visibility="gone"/>
                </LinearLayout>

                <!-- Downloaded / offline -->
                <LinearLayout
                        android:id="@+id/library_section_offline"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="OFFLINE">

                    <LinearLayout
                            android:id="@+id/library_offline_header_row"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone"
                            android:background="?attr/selectableItemBackground">

                        <TextView
                                android:id="@+id/library_offline_header"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/library_offline_header"
                                android:textStyle="bold"
                                android:textSize="16sp"/>

                        <ImageView
                                android:id="@+id/library_offline_chevron"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_expand_more_24"
                                android:contentDescription="@string/library_offline_toggle"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/library_offline_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            android:clipToPadding="false"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:visibility="gone"/>
                </LinearLayout>

                <!-- Network libraries -->
                <LinearLayout
                        android:id="@+id/library_section_smb"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="SMB">

                    <TextView
                            android:id="@+id/library_smb_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:text="@string/library_smb_header"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:visibility="gone"/>

                    <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/library_smb_list"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            android:visibility="gone"/>
                </LinearLayout>

                <!-- Media library -->
                <LinearLayout
                        android:id="@+id/library_section_media"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:tag="MEDIA">

                    <TextView
                            android:id="@+id/library_media_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp"
                            android:text="@string/library_media_header"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:visibility="gone"/>

                    <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/groupGridView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            android:clipToPadding="false"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <RelativeLayout
            android:id="@+id/library_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
        <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/icon"
                android:scaleType="centerCrop"
                android:padding="1dp"
                android:layout_centerInParent="true"
                android:alpha=".15"/>
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/library_empty"
                android:textSize="24sp"
                android:gravity="center"
                android:padding="18dp"
                android:layout_centerInParent="true"/>
    </RelativeLayout>
</FrameLayout>
