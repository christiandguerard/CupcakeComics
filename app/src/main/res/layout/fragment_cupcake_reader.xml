<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cupcake_reader_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF"
    android:keepScreenOn="true">

    <com.cupcakecomics.reader.gl.ReaderGlSurfaceView
        android:id="@+id/reader_gl_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/reader_page_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reader_continuous_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFFFF"
        android:clipToPadding="false"
        android:visibility="gone"
        android:overScrollMode="never" />

    <RelativeLayout
        android:id="@+id/reader_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">
        <include layout="@layout/progress_image" />
    </RelativeLayout>

    <TextView
        android:id="@+id/reader_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="24dp"
        android:textColor="@android:color/white"
        android:background="#99000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/reader_chrome_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#B3111111"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/reader_btn_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reader_close"
            android:src="@drawable/ic_close_24"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/reader_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/reader_btn_share"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reader_share"
            android:src="@drawable/ic_share_24"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/reader_btn_options"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reader_options"
            android:src="@drawable/ic_more_vert_24"
            app:tint="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/reader_chrome_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#B3111111"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingBottom="14dp"
        android:paddingTop="10dp"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/reader_seek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxHeight="3dp"
            android:minHeight="3dp"
            android:progressDrawable="@drawable/reader_seek_progress_green"
            android:thumb="@drawable/reader_nav_thumb" />

        <TextView
            android:id="@+id/reader_page_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="52dp"
            android:gravity="end"
            android:paddingStart="10dp"
            android:textColor="@android:color/white"
            android:textSize="13sp" />
    </LinearLayout>
</FrameLayout>
