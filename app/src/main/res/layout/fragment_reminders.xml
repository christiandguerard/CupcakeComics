<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="?android:attr/colorBackground">

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/reminders_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="8dp"
            android:paddingBottom="120dp"/>

    <TextView
            android:id="@+id/reminders_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="24dp"
            android:gravity="center"
            android:text="@string/reminders_empty"
            android:visibility="gone"/>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="16dp">

        <Button
                android:id="@+id/reminders_add_pull"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reminders_add_pull"/>

        <Button
                android:id="@+id/reminders_add_book"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/reminders_add_book"/>
    </LinearLayout>
</FrameLayout>
