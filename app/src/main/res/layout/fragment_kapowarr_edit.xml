<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
    <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/kapowarr_setup_blurb"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/kapowarr_host_label"
                android:textStyle="bold"/>
        <EditText
                android:id="@+id/kap_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:hint="@string/kapowarr_host_hint"
                android:importantForAutofill="no"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/kapowarr_api_key"
                android:textStyle="bold"/>
        <EditText
                android:id="@+id/kap_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:hint="@string/kapowarr_api_key_hint"
                android:importantForAutofill="no"/>

        <TextView
                android:id="@+id/kap_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textSize="14sp"/>

        <Button
                android:id="@+id/kap_connect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/kapowarr_connect_save"/>
    </LinearLayout>
</ScrollView>
